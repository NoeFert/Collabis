{% extends 'base.html.twig' %}

{% block title %}Explorer les annonces - Collabis{% endblock %}

{% block body %}
<div class="container py-4">
    <h2 class="fw-bold mb-4" style="font-family: 'Antonio', sans-serif; color: var(--collabis-brown);">Explorer les annonces</h2>

    {# Barre de recherche #}
    <form method="get" action="{{ path('app_post_index') }}" class="mb-4">
        <div class="input-group">
            <input type="search" name="q" value="{{ search }}" class="form-control rounded-pill" placeholder="Rechercher...">
            <button class="btn btn-primary rounded-pill ms-2" type="submit">Rechercher</button>
        </div>
    </form>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for post in posts %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 30px; padding: 20px;">
                    {# Utilisateur #}
                    <div class="d-flex align-items-center mb-3">
                        <img src="https://i.pravatar.cc/100?u={{ post.user.id|default(post.id) }}" class="rounded-circle" style="width: 45px; height: 45px; object-fit: cover;">
                        <div class="ms-2">
                            <div class="fw-bold">{{ post.user.username|default('Pseudo') }}</div>
                            <div class="small text-orange" style="color: var(--collabis-orange);">{{ post.location|default('Suisse') }}</div>
                        </div>
                    </div>

                    {# Titre #}
                    <div class="d-flex justify-content-between mb-2">
                        <h3 style="font-family: 'Antonio', sans-serif; font-size: 2rem; line-height: 0.9;">{{ post.title }}</h3>
                        <span class="badge rounded-pill border border-orange text-orange" style="color: var(--collabis-orange); border-color: var(--collabis-orange) !important;">{{ post.offerType|upper }}</span>
                    </div>

                    <p class="text-muted small">{{ post.description|slice(0, 100) }}...</p>

                    {# MOSAÏQUE #}
                    <div style="display: flex; gap: 10px; height: 180px; margin-bottom: 20px;">
                        <div style="flex: 1.2; background: #D9D9D9; border-radius: 10px; overflow: hidden;">
                            {% if post.media[0] is defined %}
                                <img src="{{ post.media[0].url starts with 'http' ? post.media[0].url : asset('uploads/' ~ post.media[0].url) }}" style="width:100%; height:100%; object-fit:cover;">
                            {% endif %}
                        </div>
                        <div style="flex: 1; display: flex; flex-direction: column; gap: 10px;">
                            <div style="flex: 1; background: #D9D9D9; border-radius: 10px;">
                                {% if post.media[1] is defined %}
                                    <img src="{{ post.media[1].url starts with 'http' ? post.media[1].url : asset('uploads/' ~ post.media[1].url) }}" style="width:100%; height:100%; object-fit:cover; border-radius: 10px;">
                                {% endif %}
                            </div>
                            <div style="flex: 1; background: #D9D9D9; border-radius: 10px;">
                                {% if post.media[2] is defined %}
                                    <img src="{{ post.media[2].url starts with 'http' ? post.media[2].url : asset('uploads/' ~ post.media[2].url) }}" style="width:100%; height:100%; object-fit:cover; border-radius: 10px;">
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <a href="{{ path('app_post_show', {id: post.id}) }}" class="btn w-100" style="background: var(--collabis-orange); color: white; border-radius: 20px; font-weight: 700;">Répondre</a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}