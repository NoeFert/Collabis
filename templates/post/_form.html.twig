{{ form_start(form, {'attr': {'class': 'post-form'}}) }}
    <div class="vstack gap-4">
        {{ form_row(form.title, {
            'label': 'Titre',
            'attr': {
                'class': 'form-control form-control-lg',
                'placeholder': 'Ex. Aide en maths, vélo à prêter...'
            }
        }) }}

        <div class="mb-3">
            <label class="form-label">Type d’annonce</label>
            <div class="d-flex gap-3 flex-wrap">
                {{ form_widget(form.offerType) }}
            </div>
            <div class="form-text text-muted">Chaque annonce reçoit un badge Offre ou Demande.</div>
        </div>

        {{ form_row(form.category, {
            'label': 'Catégorie',
            'attr': {
                'class': 'form-select'
            }
        }) }}

        {{ form_row(form.location, {
            'label': 'Localisation',
            'attr': {
                'class': 'form-control',
                'placeholder': 'Ex. Genève, Lausanne, centre-ville'
            }
        }) }}

        {{ form_row(form.description, {
            'label': 'Description',
            'attr': {
                'class': 'form-control',
                'rows': 7,
                'placeholder': 'Expliquez simplement ce que vous proposez ou recherchez.'
            }
        }) }}

        <div>
            {{ form_label(form.categories, null, {'label_attr': {'class': 'form-label'}}) }}
            <div class="row g-2">
                {% for category in form.categories %}
                    <div class="col-sm-6">
                        <div class="form-check border rounded-3 px-3 py-2 h-100">
                            {{ form_widget(category, {'attr': {'class': 'form-check-input ms-0 me-2'}}) }}
                            {{ form_label(category, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        </div>
                    </div>
                {% else %}
                    <p class="text-muted mb-0">Aucune catégorie disponible pour le moment.</p>
                {% endfor %}
            </div>
            {{ form_errors(form.categories) }}
        </div>

        {{ form_row(form.images, {
            'attr': {
                'class': 'form-control'
            },
            'help': 'Formats acceptés : JPG, PNG ou WEBP, jusqu’à 5 Mo par image.'
        }) }}
    </div>

    {{ form_rest(form) }}

    <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 mt-4 pt-4 border-top">
        <a href="{{ path('app_post_index') }}" class="btn btn-light rounded-pill px-4 order-2 order-sm-1">Annuler</a>
        <button class="btn btn-collabis rounded-pill px-4 order-1 order-sm-2">
            <i class="bi bi-check2 me-1"></i>{{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}
