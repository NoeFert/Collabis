{% extends 'base.html.twig' %}

{% block title %}Modifier l’annonce - Collabis{% endblock %}

{% block body %}
<div class="page-shell">
    <div class="page-header">
        <div>
            <p class="page-kicker">Annonce</p>
            <h1 class="fw-bold mb-0">Modifier l’annonce</h1>
        </div>
        <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-eye me-1"></i> Voir l’annonce
        </a>
    </div>

    <div class="surface-card p-4 p-md-5">
        {{ include('post/_form.html.twig', {'button_label': 'Enregistrer'}) }}
    </div>

    <div class="mt-3">
        {{ include('post/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
