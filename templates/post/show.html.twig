{% extends 'base.html.twig' %}

{% block title %}Annonce : {{ post.title }}{% endblock %}

{% block body %}
<div class="container page-shell">
    <div class="mb-4">
        <a href="{{ path('app_post_index') }}" class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Retour aux annonces
        </a>
    </div>
    <div class="row">
        <!-- Colonne Gauche : Images -->
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    {% if post.media|length > 0 %}
                        <div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
                            <div class="carousel-inner">
                                {% for image in post.media %}
                                    <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                        <img src="{{ asset('uploads/' ~ image.url) }}" class="d-block w-100 rounded" alt="Photo de l'annonce" style="height: 400px; object-fit: cover;">
                                    </div>
                                {% endfor %}
                            </div>
                            {% if post.media|length > 1 %}
                                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                </button>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 400px;">
                            <p class="text-muted">Aucune photo disponible</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Colonne Droite : Infos -->
        <div class="col-md-5">
            <h1 class="display-5 fw-bold">{{ post.title }}</h1>
            <hr>
            <p class="lead text-muted">{{ post.description }}</p>
            
            <div class="d-grid gap-2 mt-4">
                {% if app.user %}
                    {% if post.user and app.user.id == post.user.id %}
                        <button class="btn btn-outline-secondary btn-lg" type="button" disabled>
                            <i class="bi bi-person-check me-1"></i> C’est votre annonce
                        </button>
                    {% else %}
                        <form method="post" action="{{ path('app_conversation_start', {'id': post.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('start_conversation' ~ post.id) }}">
                            <button class="btn btn-success btn-lg w-100" type="submit">
                                <i class="bi bi-chat-dots me-1"></i> Contacter le propriétaire
                            </button>
                        </form>
                    {% endif %}
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-success btn-lg">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Connectez-vous pour contacter
                    </a>
                {% endif %}
                <div class="d-flex justify-content-between mt-3">
                    <a href="{{ path('app_post_index') }}" class="btn btn-outline-secondary">Explorer</a>
                    {% if app.user and post.user and app.user.id == post.user.id %}
                        <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-warning">Modifier</a>
                    {% endif %}
                </div>
                {% if app.user and post.user and app.user.id == post.user.id %}
                    <div class="mt-3">
                        {{ include('post/_delete_form.html.twig') }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
