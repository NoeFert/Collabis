{% extends 'base.html.twig' %}

{% block title %}Annonce : {{ post.title }}{% endblock %}

{% block body %}
<div class="container page-shell">
    <div class="mb-4">
        <a href="{{ path('app_post_index') }}" class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Retour aux annonces
        </a>
    </div>

    <div class="row">
        <!-- Colonne Gauche : Images -->
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-2">
                    {% if post.media|length > 0 %}
                        <div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
                            <div class="carousel-inner">
                                {% for image in post.media %}
                                    <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                        {# --- CORRECTION ICI : GESTION DES URLS EXTERNES --- #}
                                        {% if 'http' in image.url %}
                                            <img src="{{ image.url }}" class="d-block w-100 rounded" alt="Photo de l'annonce" style="height: 500px; object-fit: cover;">
                                        {% else %}
                                            <img src="{{ asset('uploads/' ~ image.url) }}" class="d-block w-100 rounded" alt="Photo de l'annonce" style="height: 500px; object-fit: cover;">
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                            
                            {% if post.media|length > 1 %}
                                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                </button>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 400px;">
                            <div class="text-center">
                                <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                                <p class="text-muted mt-2">Aucune photo disponible</p>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Colonne Droite : Infos -->
        <div class="col-md-5">
            <div class="ps-md-4">
                <h1 class="display-6 fw-bold text-dark">{{ post.title }}</h1>
                
                {# Petit badge pour la catégorie #}
                {% for category in post.categories %}
                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 mb-3">{{ category.label }}</span>
                {% endfor %}

                <hr class="my-4 opacity-10">
                
                <h5 class="fw-bold mb-3">Description</h5>
                <p class="text-muted" style="line-height: 1.7; white-space: pre-wrap;">{{ post.description }}</p>
                
                <div class="card bg-light border-0 mt-5">
                    <div class="card-body p-4">
                        <div class="d-grid gap-3">
                            {% if app.user %}
                                {% if post.user and app.user.id == post.user.id %}
                                    <button class="btn btn-secondary btn-lg rounded-pill" disabled>
                                        <i class="bi bi-person-check me-2"></i>C’est votre annonce
                                    </button>
                                {% else %}
                                    <form method="post" action="{{ path('app_conversation_start', {'id': post.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('start_conversation' ~ post.id) }}">
                                        <button class="btn btn-success btn-lg w-100 rounded-pill shadow-sm" type="submit">
                                            <i class="bi bi-chat-dots me-2"></i>Contacter le propriétaire
                                        </button>
                                    </form>
                                {% endif %}
                            {% else %}
                                <a href="{{ path('app_login') }}" class="btn btn-success btn-lg rounded-pill shadow-sm">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter pour contacter
                                </a>
                            {% endif %}
                            
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_post_index') }}" class="btn btn-outline-secondary rounded-pill flex-grow-1">
                                    Explorer
                                </a>
                                {% if app.user and post.user and app.user.id == post.user.id %}
                                    <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-warning rounded-pill px-4">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                {% endif %}
                            </div>

                            {% if app.user and post.user and app.user.id == post.user.id %}
                                <div class="mt-2 text-center">
                                    {{ include('post/_delete_form.html.twig') }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}