{% extends 'base.html.twig' %}

{% block title %}Collabis - Entraide & Services{% endblock %}

{% block body %}
    {# --- SECTION HERO (Bannière) --- #}
    <div class="py-5 mb-5 bg-dark text-white rounded-bottom-5 shadow-lg" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1521737711867-e3b97375f902?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80'); background-size: cover; background-position: center;">
        <div class="container py-5 text-center">
            <h1 class="display-3 fw-bold">Collabis</h1>
            <p class="fs-4 mb-4">La plateforme d'entraide locale. Échangez vos compétences, partagez vos outils.</p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a href="{{ path('app_post_new') }}" class="btn btn-primary btn-lg px-4 gap-3 shadow">Déposer une annonce</a>
                <a href="{{ path('app_post_index') }}" class="btn btn-outline-light btn-lg px-4 shadow">Voir tout</a>
            </div>
        </div>
    </div>

    <div class="container mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Dernières annonces</h2>
            <a href="{{ path('app_post_index') }}" class="text-decoration-none text-primary">Tout voir &rarr;</a>
        </div>

        {# --- GRILLE D'ANNONCES --- #}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for post in posts %}
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm transition-hover">
                        
                        {# --- CORRECTION DE L'IMAGE ICI --- #}
                        {% if post.media|length > 0 %}
                            {% if 'http' in post.media[0].url %}
                                <img src="{{ post.media[0].url }}" class="card-img-top rounded-top-3" alt="{{ post.title }}" style="height: 200px; object-fit: cover;">
                            {% else %}
                                <img src="{{ asset('uploads/' ~ post.media[0].url) }}" class="card-img-top rounded-top-3" alt="{{ post.title }}" style="height: 200px; object-fit: cover;">
                            {% endif %}
                        {% else %}
                            <div class="bg-light text-center py-5 rounded-top-3">
                                <span class="text-muted">Pas de photo</span>
                            </div>
                        {% endif %}

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark">{{ post.title }}</h5>
                            <p class="card-text text-muted flex-grow-1">
                                {{ post.description|slice(0, 100) }}...
                            </p>
                            <div class="mt-3">
                                <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-outline-primary w-100 rounded-pill">Détails</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <p class="lead">Aucune annonce pour le moment. Soyez le premier !</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {# --- PETIT CSS POUR L'EFFET AU SURVOL --- #}
    <style>
        .transition-hover {
            transition: transform 0.3s ease, shadow 0.3s ease;
        }
        .transition-hover:hover {
            transform: translateY(-10px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
        }
        .rounded-bottom-5 { border-bottom-left-radius: 3rem !important; border-bottom-right-radius: 3rem !important; }
        .rounded-top-3 { border-top-left-radius: 1rem !important; border-top-right-radius: 1rem !important; }
    </style>
{% endblock %}