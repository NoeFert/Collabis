{% extends 'base.html.twig' %}

{% block title %}Collabis - Accueil{% endblock %}

{% block body %}
<section class="page-shell">
    <div class="section-heading">
        <h1 class="fw-bold m-0">Dernières annonces</h1>
        <a href="{{ path('app_post_index') }}" class="section-link">
            Tout voir <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for post in posts %}
            <div class="col">
                <article class="post-card">
                    {% set authorName = post.user ? post.user.username|default('Pseudo') : 'Pseudo' %}
                    <div class="post-card-user">
                        {% if post.user and post.user.avatarUrl %}
                            {% set avatarUrl = post.user.avatarUrl starts with 'http' ? post.user.avatarUrl : asset('uploads/' ~ post.user.avatarUrl) %}
                            <img src="{{ avatarUrl }}" class="avatar-img avatar-sm" alt="Avatar de {{ authorName }}">
                        {% else %}
                            <div class="avatar-placeholder avatar-sm" aria-label="Avatar de {{ authorName }}">
                                {{ authorName|slice(0, 1)|upper }}
                            </div>
                        {% endif %}
                        <div class="min-w-0">
                            <div class="post-card-user-name">{{ authorName }}</div>
                            <div class="post-card-user-location">{{ post.location|default('Suisse') }}</div>
                        </div>
                    </div>

                    <div class="post-card-heading">
                        <h2 class="post-card-title">{{ post.title }}</h2>
                        <span class="post-offer-badge">{{ post.offerType|default('demande')|upper }}</span>
                    </div>

                    <p class="post-card-description">
                        {{ post.description|default('Aucune description pour le moment.')|slice(0, 140) }}{% if post.description|length > 140 %}...{% endif %}
                    </p>

                    {% set media_count = post.media|length %}
                    {% if media_count > 0 %}
                        <div class="post-card-media {{ media_count == 1 ? 'post-card-media--single' : '' }}">
                            <div class="post-card-media-cell post-card-media-main">
                                <img src="{{ post.media[0].url starts with 'http' ? post.media[0].url : asset('uploads/' ~ post.media[0].url) }}" alt="Photo de {{ post.title }}">
                            </div>
                            {% if media_count > 1 %}
                                <div class="post-card-media-secondary">
                                    <div class="post-card-media-cell">
                                        <img src="{{ post.media[1].url starts with 'http' ? post.media[1].url : asset('uploads/' ~ post.media[1].url) }}" alt="">
                                    </div>
                                    {% if media_count > 2 %}
                                        <div class="post-card-media-cell">
                                            <img src="{{ post.media[2].url starts with 'http' ? post.media[2].url : asset('uploads/' ~ post.media[2].url) }}" alt="">
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}

                    <div class="post-card-action">
                        <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-collabis w-100">
                            Répondre
                        </a>
                    </div>
                </article>
            </div>
        {% else %}
            <div class="col-12">
                <div class="empty-state">
                    <h2 class="h4 fw-bold">Aucune annonce pour le moment</h2>
                    <p class="text-muted mb-4">Publiez la première annonce et lancez l’entraide.</p>
                    <a href="{{ path('app_post_new') }}" class="btn btn-collabis rounded-pill px-4">Publier une annonce</a>
                </div>
            </div>
        {% endfor %}
    </div>
</section>
{% endblock %}
