{% extends 'base.html.twig' %}

{% block title %}Collabis - Accueil{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0" style="font-family: 'Antonio', sans-serif; color: var(--collabis-brown);">Dernières annonces</h2>
        <a href="{{ path('app_post_index') }}" class="text-decoration-none" style="color: var(--collabis-orange); font-weight: 700;">TOUT VOIR &rarr;</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for post in posts %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 30px; padding: 20px; background: #fff;">
                    
                    {# 1. HEADER : Utilisateur #}
                    <div class="d-flex align-items-center mb-3">
                        <img src="https://i.pravatar.cc/100?u={{ post.user.id|default(post.id) }}" class="rounded-circle" style="width: 45px; height: 45px; object-fit: cover;" alt="Avatar">
                        <div class="ms-2">
                            <div class="fw-bold" style="color: var(--collabis-brown); font-size: 1rem; line-height: 1;">{{ post.user.username|default('Pseudo') }}</div>
                            <div style="color: var(--collabis-orange); font-size: 0.75rem; font-weight: 600;">Localisation</div>
                        </div>
                    </div>

                    {# 2. TITRE ET BADGE #}
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 style="font-family: 'Antonio', sans-serif; font-weight: 700; font-size: 2rem; color: var(--collabis-brown); margin: 0; line-height: 0.9;">
                            {{ post.title }}
                        </h3>
                        <span style="border: 1.5px solid var(--collabis-orange); color: var(--collabis-orange); border-radius: 15px; padding: 2px 10px; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">
                            Demande
                        </span>
                    </div>

                    {# 3. DESCRIPTION #}
                    <p style="font-size: 0.9rem; line-height: 1.4; color: var(--collabis-brown); opacity: 0.8; margin-bottom: 15px;">
                        {{ post.description|slice(0, 140) }}...
                    </p>

                    {# 4. GRILLE D'IMAGES (Mosaïque compatible Faker/Picsum) #}
                    <div style="display: flex; gap: 10px; height: 180px; margin-bottom: 20px;">
                        <div style="flex: 1.2; background-color: #D9D9D9; border-radius: 10px; overflow: hidden;">
                            {% if post.media[0] is defined %}
                                <img src="{{ post.media[0].url starts with 'http' ? post.media[0].url : asset('uploads/' ~ post.media[0].url) }}" style="width: 100%; height: 100%; object-fit: cover;">
                            {% endif %}
                        </div>
                        <div style="flex: 1; display: flex; flex-direction: column; gap: 10px;">
                            <div style="flex: 1; background-color: #D9D9D9; border-radius: 10px; overflow: hidden;">
                                {% if post.media[1] is defined %}
                                    <img src="{{ post.media[1].url starts with 'http' ? post.media[1].url : asset('uploads/' ~ post.media[1].url) }}" style="width: 100%; height: 100%; object-fit: cover;">
                                {% endif %}
                            </div>
                            <div style="flex: 1; background-color: #D9D9D9; border-radius: 10px; overflow: hidden;">
                                {% if post.media[2] is defined %}
                                    <img src="{{ post.media[2].url starts with 'http' ? post.media[2].url : asset('uploads/' ~ post.media[2].url) }}" style="width: 100%; height: 100%; object-fit: cover;">
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# 5. BOUTON RÉPONDRE #}
                    <div class="mt-auto">
                        <a href="{{ path('app_post_show', {'id': post.id}) }}" 
                           style="background-color: var(--collabis-orange); color: white; text-decoration: none; padding: 10px 25px; border-radius: 25px; font-weight: 700; font-size: 0.9rem; display: inline-block;">
                            Répondre
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}