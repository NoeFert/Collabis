<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Collabis - Plateforme d'entraide{% endblock %}</title>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        <link href="https://fonts.googleapis.com/css2?family=Antonio:wght@700&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">

        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        
        <header class="header-container container">
            <div class="site-header-main">
                <a href="{{ path('app_home') }}" class="logo-brand">
                    <img src="{{ asset('images/logo_sombre.png') }}" alt="Collabis Logo">
                </a>

                <div class="top-actions">
                    <a href="{{ app.user ? path('app_conversation') : path('app_login') }}" class="nav-icon" title="Messages" aria-label="Messages">
                        <i class="bi bi-chat-left-text"></i>
                    </a>
                    <a href="{{ app.user ? path('app_post_new') : path('app_login') }}" class="btn-publier" aria-label="Publier une annonce">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span>Publier</span>
                    </a>
                    <a href="{{ app.user ? path('app_my_profile') : path('app_login') }}" class="nav-icon" title="{{ app.user ? 'Mon profil' : 'Connexion' }}" aria-label="{{ app.user ? 'Mon profil' : 'Connexion' }}">
                        {% if app.user and app.user.avatarUrl %}
                            {% set headerAvatarUrl = app.user.avatarUrl starts with 'http' ? app.user.avatarUrl : asset('uploads/' ~ app.user.avatarUrl) %}
                            <img src="{{ headerAvatarUrl }}" alt="">
                        {% else %}
                            <i class="bi bi-person-circle"></i>
                        {% endif %}
                    </a>
                </div>
            </div>

            <div class="search-filter-row">
                <form action="{{ path('app_post_index') }}" method="get" class="search-wrapper" role="search">
                    <input type="hidden" name="offer" value="{{ app.request.get('offer') }}">
                    <input type="text" name="q" class="search-bar" placeholder="Recherche" value="{{ app.request.get('q') }}">
                    <button class="search-submit" type="submit" aria-label="Rechercher">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
                
                <div class="filters-group">
                    <a href="{{ path('app_post_index', {'q': app.request.get('q')}) }}" class="filter-btn{{ app.request.get('offer') is empty ? ' active' : '' }}">Tous</a>
                    <a href="{{ path('app_post_index', {'offer': 'offre', 'q': app.request.get('q')}) }}" class="filter-btn{{ app.request.get('offer') == 'offre' ? ' active' : '' }}">Offre</a>
                    <a href="{{ path('app_post_index', {'offer': 'demande', 'q': app.request.get('q')}) }}" class="filter-btn{{ app.request.get('offer') == 'demande' ? ' active' : '' }}">Demande</a>
                </div>
            </div>
        </header>

        <main class="{% block main_class %}app-main container{% endblock %}">
            {% set flashMessages = app.flashes %}
            {% if flashMessages is not empty %}
                <div class="flash-stack">
                    {% for label, messages in flashMessages %}
                        {% set alertType = label == 'error' ? 'danger' : label %}
                        {% for message in messages %}
                            <div class="alert alert-{{ alertType }} mb-3" role="alert">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}
                </div>
            {% endif %}
            {% block body %}{% endblock %}
        </main>

        <footer class="py-5 text-center mt-auto">
            <p class="text-muted small">© {{ "now"|date("Y") }} Collabis.ch — Plateforme d'entraide locale</p>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
        <script src="{{ asset('js/csrf-protection.js') }}" defer></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
