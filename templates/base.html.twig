<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <icon rel="shortcut icon" href="data:image/x-icon;base64,..." />

        {# --- ICI ON AJOUTE BOOTSTRAP --- #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {# Ajoute aussi le JS de Bootstrap pour que les menus et carrousels fonctionnent #}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
        {% endblock %}
    </head>
    <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">COLLABIS</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>   
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_post_index') }}">Annonces</a>
                </li>
                <li class="nav-item">
                    <a class="btn btn-primary ms-lg-3" href="{{ path('app_post_new') }}">Publier</a>
                </li>
            </ul>
        </div>
    </div>
</nav>
        {% block body %}{% endblock %}
    </body>
</html>