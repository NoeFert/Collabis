{% extends 'base.html.twig' %}

{% block title %}Profil public - Collabis{% endblock %}

{% block body %}
<div class="container page-shell">
    <div class="mb-4">
        <a href="{{ path('app_post_index') }}" class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Retour aux annonces
        </a>
    </div>

    <div class="bg-white border rounded-3 p-4 shadow-sm d-flex align-items-center gap-3">
        {% if user.avatarUrl %}
            {% set avatarUrl = user.avatarUrl starts with 'http' ? user.avatarUrl : asset('uploads/' ~ user.avatarUrl) %}
            <img src="{{ avatarUrl }}" alt="Avatar de {{ user.username }}" class="rounded-circle object-fit-cover" style="width: 72px; height: 72px;">
        {% else %}
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 72px; height: 72px;">
                {{ user.username|slice(0, 1)|upper }}
            </div>
        {% endif %}
        <div>
            <p class="page-kicker mb-1">Profil public</p>
            <h1 class="fw-bold mb-1">{{ user.username }}</h1>
            <p class="text-muted mb-0">Membre Collabis</p>
        </div>
    </div>
</div>
{% endblock %}
