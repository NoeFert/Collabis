{% extends 'base.html.twig' %}

{% block title %}Profil public - Collabis{% endblock %}

{% block body %}
<div class="page-shell">
    <div class="mb-4">
        <a href="{{ path('app_post_index') }}" class="section-link">
            <i class="bi bi-arrow-left me-1"></i> Retour aux annonces
        </a>
    </div>

    <div class="surface-card profile-summary">
        {% if user.avatarUrl %}
            {% set avatarUrl = user.avatarUrl starts with 'http' ? user.avatarUrl : asset('uploads/' ~ user.avatarUrl) %}
            <img src="{{ avatarUrl }}" alt="Avatar de {{ user.username }}" class="avatar-img avatar-xl">
        {% else %}
            <div class="avatar-placeholder avatar-xl">
                {{ user.username|slice(0, 1)|upper }}
            </div>
        {% endif %}
        <div>
            <p class="page-kicker mb-1">Profil public</p>
            <h1 class="fw-bold mb-1">{{ user.username }}</h1>
            {% if user.bio %}
                <p class="text-muted mb-0">{{ user.bio|nl2br }}</p>
            {% else %}
                <p class="text-muted mb-0">Membre Collabis</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
