{% extends 'base.html.twig' %}

{% block title %}Éditer mon profil - Collabis{% endblock %}

{% block body %}
{% set user = app.user %}
<div class="page-shell">
    <div class="mb-4">
        <a href="{{ path('app_my_profile') }}" class="section-link">
            <i class="bi bi-arrow-left me-1"></i> Retour au profil
        </a>
    </div>

    <div class="page-header mb-5">
        <div>
            <p class="page-kicker">Compte</p>
            <h1 class="fw-bold mb-0">Modifier mon profil</h1>
        </div>
    </div>

    <div class="surface-card profile-edit-card p-4 p-md-5 mx-auto">
        {% if form.vars.errors|length > 0 %}
            <div class="alert alert-danger mb-4" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>
                <strong>Des erreurs se sont produites:</strong>
                <ul class="mb-0 mt-2">
                    {% for error in form.vars.errors %}
                        <li>{{ error.message }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {{ form_start(form, {'attr': {'method': 'POST', 'novalidate': true}}) }}

        <div class="mb-4">
            <h3 class="h5 fw-bold mb-3">Photo de profil</h3>
            {% if user.avatarUrl %}
                {% set avatarUrl = user.avatarUrl starts with 'http' ? user.avatarUrl : asset('uploads/' ~ user.avatarUrl) %}
                <div class="mb-3">
                    <img src="{{ avatarUrl }}" alt="Avatar actuel" class="avatar-img avatar-lg">
                </div>
            {% else %}
                <div class="avatar-placeholder avatar-lg">
                    {{ user.email|slice(0, 1)|upper }}
                </div>
            {% endif %}
            <div class="mb-3">
                {{ form_row(form.avatar, {'attr': {'class': 'form-control'}}) }}
            </div>
        </div>

        <hr class="my-4">

        <div class="mb-4">
            <h3 class="h5 fw-bold mb-3">Informations personnelles</h3>
            
            <div class="mb-3">
                {{ form_label(form.username, 'Nom d\'utilisateur') }}
                {{ form_widget(form.username, {'attr': {'class': 'profile-input form-control'}}) }}
                {{ form_errors(form.username) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.email, 'Adresse email') }}
                {{ form_widget(form.email, {'attr': {'class': 'profile-input form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>
        </div>

        <hr class="my-4">

        <div class="mb-4">
            <h3 class="h5 fw-bold mb-3">Biographie</h3>
            {{ form_label(form.bio, 'Votre biographie') }}
            {{ form_widget(form.bio, {'attr': {'class': 'profile-input form-control', 'rows': '5'}}) }}
            {{ form_errors(form.bio) }}
            <small class="text-muted d-block mt-2">Présentez-vous en quelques mots pour les autres utilisateurs.</small>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-collabis rounded-pill px-4">
                <i class="bi bi-check-lg me-1"></i> Enregistrer les modifications
            </button>
            <a href="{{ path('app_my_profile') }}" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-x-lg me-1"></i> Annuler
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
