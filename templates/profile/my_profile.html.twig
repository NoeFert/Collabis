{% extends 'base.html.twig' %}

{% block title %}Mon profil - Collabis{% endblock %}

{% block body %}
{% set user = app.user %}
<div class="container page-shell">
    <div class="page-header">
        <div>
            <p class="page-kicker">Compte</p>
            <h1 class="fw-bold mb-0">Mon profil</h1>
        </div>
        <a href="{{ path('app_post_new') }}" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-lg me-1"></i> Publier
        </a>
    </div>

    <div class="bg-white border rounded-3 p-4 shadow-sm d-flex align-items-center gap-3">
        {% if user.avatarUrl %}
            {% set avatarUrl = user.avatarUrl starts with 'http' ? user.avatarUrl : asset('uploads/' ~ user.avatarUrl) %}
            <img src="{{ avatarUrl }}" alt="Avatar de {{ user.email }}" class="rounded-circle object-fit-cover" style="width: 64px; height: 64px;">
        {% else %}
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 64px; height: 64px;">
                {{ user.email|slice(0, 1)|upper }}
            </div>
        {% endif %}
        <div>
            <h2 class="h4 fw-bold mb-1">{{ user.email }}</h2>
            <p class="text-muted mb-0">Retrouvez vos messages et vos annonces depuis la navigation principale.</p>
        </div>
    </div>

    <section class="mt-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <p class="page-kicker mb-1">Annonces</p>
                <h2 class="h3 fw-bold mb-0">Mes annonces</h2>
            </div>
            <a href="{{ path('app_post_new') }}" class="btn btn-outline-primary rounded-pill px-4 align-self-start align-self-md-center">
                <i class="bi bi-plus-lg me-1"></i> Nouvelle annonce
            </a>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for post in posts %}
                <div class="col">
                    <article class="card h-100 border-0 shadow-sm">
                        {% if post.media|length > 0 %}
                            {% set imageUrl = post.media[0].url starts with 'http' ? post.media[0].url : asset('uploads/' ~ post.media[0].url) %}
                            <img src="{{ imageUrl }}" class="card-img-top" alt="{{ post.title }}" style="height: 190px; object-fit: cover;">
                        {% else %}
                            <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="height: 190px;">
                                <i class="bi bi-image fs-1"></i>
                            </div>
                        {% endif %}

                        <div class="card-body d-flex flex-column">
                            <h3 class="h5 fw-bold">{{ post.title }}</h3>

                            {% if post.categories|length > 0 %}
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    {% for category in post.categories %}
                                        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">{{ category.label }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            <p class="text-muted flex-grow-1">
                                {{ post.description|default('Aucune description pour le moment.')|slice(0, 120) }}{% if post.description|length > 120 %}...{% endif %}
                            </p>

                            <div class="d-flex gap-2">
                                <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-outline-primary rounded-pill flex-grow-1">Voir</a>
                                <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-light rounded-circle" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="text-center bg-white border rounded-3 py-5 px-4">
                        <h3 class="h4 fw-bold">Vous n’avez pas encore publié d’annonce</h3>
                        <p class="text-muted mb-4">Créez votre première annonce pour la retrouver ensuite directement ici.</p>
                        <a href="{{ path('app_post_new') }}" class="btn btn-primary rounded-pill px-4">Créer une annonce</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>
</div>
{% endblock %}
