{% extends 'base.html.twig' %}

{% block title %}Inscription - Collabis{% endblock %}

{% block body %}
<div class="auth-shell">
    <div class="auth-card">
        <div class="row g-0">
            <div class="col-lg-6">
                <div class="auth-form-panel d-flex flex-column justify-content-center">
                    <div class="mb-4">
                        <p class="page-kicker">Inscription</p>
                        <h1 class="fw-bold mb-2">Créer un compte</h1>
                        <p class="text-muted mb-0">Rejoignez Collabis et commencez à partager.</p>
                    </div>

                    <div class="auth-switch d-flex mb-4">
                        <a href="{{ path('app_login') }}">Connexion</a>
                        <a href="{{ path('app_register') }}" class="active">Inscription</a>
                    </div>

                    {{ form_start(registrationForm, {'attr': {'class': 'vstack gap-3'}}) }}
                        {{ form_row(registrationForm.username, {
                            'label': 'Nom d’utilisateur',
                            'attr': {'class': 'form-control auth-input', 'placeholder': 'Ex. Lina, Maxime...'}
                        }) }}

                        {{ form_row(registrationForm.email, {
                            'label': 'Adresse email',
                            'attr': {'class': 'form-control auth-input', 'placeholder': 'vous@collabis.ch'}
                        }) }}

                        {{ form_row(registrationForm.plainPassword, {
                            'label': 'Mot de passe',
                            'attr': {'class': 'form-control auth-input', 'placeholder': 'Au moins 6 caractères'}
                        }) }}

                        {{ form_row(registrationForm.avatar, {
                            'attr': {'class': 'form-control auth-input'},
                            'help': 'Optionnel. Ajoutez votre plus beau sourire !'
                        }) }}

                        <div class="auth-terms mt-2">
                            <div class="form-check mb-0">
                                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(registrationForm.agreeTerms, 'J’accepte les conditions d’utilisation.', {
                                    'label_attr': {'class': 'form-check-label fw-bold', 'style': 'color: var(--collabis-brown); font-size: 0.9rem;'}
                                }) }}
                            </div>
                            {{ form_errors(registrationForm.agreeTerms) }}
                        </div>

                        <button type="submit" class="btn btn-collabis btn-lg mt-3">
                            S’inscrire sur Collabis
                        </button>
                    {{ form_end(registrationForm) }}
                </div>
            </div>

            <div class="col-lg-6 d-none d-lg-block">
                <aside class="auth-side-panel auth-side-panel--centered">
                    <div>
                        <h2 class="display-5 fw-bold mb-3">
                            PRÊTEZ UNE MAIN,<br>TROUVEZ UNE SOLUTION.
                        </h2>
                        <p class="fs-5 opacity-75">Collabis est la plateforme d'entraide où chaque coup de main compte.</p>
                        
                        <img src="{{ asset('images/STICKER_MAIN.svg') }}" alt="Entraide" class="sticker-img">
                    </div>

                    <div class="auth-side-footer">
                        COLLABIS.CH
                    </div>
                </aside>
            </div>
        </div>
    </div>
</div>
{% endblock %}
