{% extends 'base.html.twig' %}

{% block title %}Connexion - Collabis{% endblock %}

{% block body %}
<div class="auth-shell">
    <div class="auth-card">
        <div class="row g-0">
            <div class="col-lg-6">
                <div class="auth-form-panel d-flex flex-column justify-content-center">
                    <div class="mb-4">
                        <p class="page-kicker">Connexion</p>
                        <h1 class="fw-bold mb-2">Ravi de vous revoir</h1>
                        <p class="text-muted mb-0">Connectez-vous pour publier une annonce, répondre aux étudiants et retrouver vos conversations.</p>
                    </div>

                    <div class="auth-switch d-flex mb-4">
                        <a href="{{ path('app_login') }}" class="active">Connexion</a>
                        <a href="{{ path('app_register') }}">Inscription</a>
                    </div>

                    {% if error %}
                        <div class="alert alert-danger rounded-3">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info rounded-3">
                            Vous êtes connecté avec {{ app.user.userIdentifier }}.
                            <a href="{{ logout_path() }}" class="alert-link">Se déconnecter</a>
                        </div>
                    {% endif %}

                    <form method="post" class="vstack gap-3">
                        <div>
                            <label for="inputEmail" class="form-label fw-semibold">Adresse email</label>
                            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control auth-input" autocomplete="email" placeholder="vous@collabis.ch" required autofocus>
                        </div>

                        <div>
                            <label for="inputPassword" class="form-label fw-semibold">Mot de passe</label>
                            <input type="password" name="password" id="inputPassword" class="form-control auth-input" autocomplete="current-password" placeholder="Votre mot de passe" required>
                        </div>

                        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                        <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                                <label class="form-check-label text-muted" for="rememberMe">Se souvenir de moi</label>
                            </div>
                            <a href="{{ path('app_register') }}" class="auth-inline-link">Créer un compte</a>
                        </div>

                        <button class="btn btn-collabis btn-lg rounded-pill mt-2" type="submit">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Se connecter
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-6">
                <aside class="auth-side-panel d-flex flex-column justify-content-between">
                    <div>
                        <a class="auth-side-brand d-inline-flex align-items-center text-decoration-none fw-bold fs-4 mb-5" href="{{ path('app_home') }}">
                            <i class="bi bi-rocket-takeoff-fill me-2"></i> COLLABIS
                        </a>
                        <h2 class="display-6 fw-bold mb-3">Une annonce peut lancer une vraie entraide.</h2>
                        <p class="mb-4 opacity-75">Rejoignez les échanges du campus, proposez vos compétences et trouvez rapidement les ressources qui vous manquent.</p>
                        <a href="{{ path('app_register') }}" class="btn btn-outline-light rounded-pill px-4">
                            S’inscrire
                        </a>
                    </div>

                    <div class="auth-floating-card p-4 mt-5">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="feature-icon">
                                <i class="bi bi-chat-heart fs-4"></i>
                            </div>
                            <div>
                                <p class="fw-bold mb-0">Messagerie intégrée</p>
                                <small class="opacity-75">Contactez directement depuis une annonce.</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="feature-icon">
                                <i class="bi bi-people fs-4"></i>
                            </div>
                            <div>
                                <p class="fw-bold mb-0">Communauté étudiante</p>
                                <small class="opacity-75">Des échanges simples, locaux et utiles.</small>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>
</div>
{% endblock %}
